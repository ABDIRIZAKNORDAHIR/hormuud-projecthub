{
  "name": "hormuud-projecthub",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "build": "vite build",
    "build:app": "vite build",
    "preview:app": "vite preview --port 5180 --strictPort",
    "dev": "vite",
    "dev:server": "npm run dev --prefix server",
    "seed": "npm run seed --prefix server",
    "setup:db": "node server/src/setupDatabase.js",
    "setup:db:cloud": "node server/src/setupDatabasePg.js",
    "test-ai": "npm run test-ai --prefix server",
    "setup:ai": "node scripts/setup-ai-key.mjs",
    "setup:free-ai": "node scripts/setup-groq-key.mjs",
    "start:server": "npm run start --prefix server",
    "start": "node scripts/start-full-stack.mjs",
    "start:all": "node scripts/start-full-stack.mjs",
    "start:production": "node scripts/start-production.mjs",
    "share:internet": "node scripts/share-internet.mjs",
    "desktop:icon": "node scripts/build-desktop-icon.mjs",
    "desktop": "electron .",
    "desktop:build": "npm run desktop:icon && electron-builder --win portable",
    "export:db": "node server/src/scripts/exportDatabase.js",
    "health-check": "node scripts/health-check.mjs",
    "export:figma-screens": "node scripts/export-figma-screens.mjs",
    "export:photoshop": "node scripts/export-photoshop.mjs",
    "export:promo-video": "node scripts/export-promo-video.mjs"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.5",
    "@mui/material": "7.3.5",
    "@popperjs/core": "2.11.8",
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.2",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-collapsible": "1.1.3",
    "@radix-ui/react-context-menu": "2.2.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-hover-card": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-menubar": "1.1.6",
    "@radix-ui/react-navigation-menu": "1.2.5",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toggle": "1.1.2",
    "@radix-ui/react-toggle-group": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "ag-psd": "^30.1.1",
    "canvas-confetti": "1.9.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "3.6.0",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "next-themes": "0.4.6",
    "react": "18.3.1",
    "react-day-picker": "8.10.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.55.0",
    "react-popper": "2.3.0",
    "react-resizable-panels": "2.1.7",
    "react-responsive-masonry": "2.7.1",
    "react-router": "7.13.0",
    "react-slick": "0.31.0",
    "recharts": "2.15.2",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@tailwindcss/vite": "4.1.12",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "playwright": "^1.61.0",
    "sharp": "^0.35.1",
    "tailwindcss": "4.1.12",
    "vite": "6.3.5",
    "vite-plugin-pwa": "^1.3.0"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  },
  "build": {
    "appId": "so.edu.hu.projecthub",
    "productName": "Hormuud ProjectHub",
    "copyright": "Hormuud University",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "desktop/app-config.cloud.json",
        "to": "app-config.json"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "desktop/icon.png",
      "artifactName": "Hormuud-ProjectHub-${version}-Portable.${ext}",
      "signAndEditExecutable": false
    }
  }
}
