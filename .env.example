# Real AI — OpenAI ChatGPT and/or Google Gemini (teacher project analysis & Q&A)
# Add at least ONE key below (see CONFIGURE_REAL_AI.txt)

# Option A — OpenAI ChatGPT (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Option B — Google Gemini (https://aistudio.google.com/apikey)
# GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Provider: auto (default) | openai | gemini
AI_PROVIDER=auto
# If primary provider fails, try the other (true unless set to false)
AI_FALLBACK=true
